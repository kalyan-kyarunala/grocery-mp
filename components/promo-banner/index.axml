<view class="pb" style="background:{{promo.bg}}" onTap="tap">
  <!-- ground -->
  <view class="pb__ground"></view>

  <!-- main offer content, sits below the location/search header that overlaps this banner -->
  <view class="pb__content">
    <view class="pb__sticker">
      <text class="pb__kicker">{{promo.kicker}}</text>
      <view class="pb__amtrow">
        <text class="pb__amt">{{promo.amount}}</text>
        <text class="pb__off">{{promo.off}}</text>
      </view>
    </view>
    <text class="pb__sub">{{promo.subtitle}}</text>

    <view class="pb__spacer"></view>

    <!-- mascots -->
    <view class="pb__cast">
      <image class="pb__mascot" a:for="{{promo.mascots}}" a:key="src" src="{{item.src}}" mode="aspectFit" style="animation-delay:{{item.delay}}ms" />
    </view>

    <!-- cta -->
    <view class="pb__cta">
      <text class="pb__ctatxt">{{promo.cta}}</text>
      <fa-icon name="chevron-right" size="26" color="#ffffff" />
    </view>
  </view>

  <!-- shine sweep -->
  <view class="pb__shine"></view>
</view>
