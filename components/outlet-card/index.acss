.oc.card { width: 100%; border: none; border-radius: 22rpx; box-shadow: 0 6rpx 20rpx rgba(15,32,80,.09); }
.oc__banner { height: 200rpx; display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden; }
.oc__img { width: 100%; height: 100%; }
.oc__badge { position: absolute; top: 16rpx; left: 16rpx; box-shadow: 0 4rpx 10rpx rgba(0,0,0,.2); }
.oc__body { padding: 22rpx 22rpx 24rpx; align-items: center; }
.oc__name { font-size: 30rpx; font-weight: 700; color: var(--c-text); }
.oc__metatxt { font-size: 23rpx; color: var(--c-muted); font-weight: 500; }
.oc__dot { width: 6rpx; height: 6rpx; border-radius: 50%; background: var(--c-line); flex: none; }
