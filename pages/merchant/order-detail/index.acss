.avatar { width: 76rpx; height: 76rpx; border-radius: 50%; background: var(--c-primary-50); color: var(--c-primary); display: flex; align-items: center; justify-content: center; font-weight: 600; }
.callbtn { width: 76rpx; height: 76rpx; min-width: 76rpx; background: var(--c-primary); border-radius: 18rpx; }
.li { padding: 14rpx 0; border-bottom: 1rpx solid #F0EFE9; }
