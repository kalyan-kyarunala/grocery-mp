.seg { display: flex; gap: 0; background: #F1F1EE; border-radius: 20rpx; padding: 6rpx; margin: 24rpx 28rpx; }
.seg__opt { flex: 1; display: flex; align-items: center; justify-content: center; gap: 10rpx; min-height: 76rpx; border-radius: 16rpx; font-size: 26rpx; color: var(--c-muted); }
.seg__opt--on { background: var(--c-primary); color: #fff; font-weight: 600; }
.ci { display: flex; align-items: center; gap: 18rpx; padding: 18rpx 0; border-bottom: 1rpx solid #F0EFE9; }
.ci__thumb { width: 88rpx; height: 88rpx; border-radius: 16rpx; display: flex; align-items: center; justify-content: center; }
.field { background: #fff; border: 1rpx solid #E3E1D9; border-radius: 14rpx; min-height: 80rpx; padding: 0 20rpx; font-size: 26rpx; }
.empty { display: flex; flex-direction: column; align-items: center; padding: 100rpx 0; }
